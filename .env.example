# Sanity (Phase 1) — copy to `.env` or `.env.local` and fill in from https://www.sanity.io/manage
# Next (`yarn dev`) loads these automatically. `yarn studio:dev` loads them via scripts/studio-dev.mjs; plain `sanity dev` does not.
# Studio: embedded `http://localhost:3000/studio` (with `yarn dev`) or standalone `http://localhost:3333` (with `yarn studio:dev`).
# For standalone Studio, Sanity’s Vite only exposes `SANITY_STUDIO_*` to the browser; `yarn studio:dev` copies from NEXT_PUBLIC_* if you omit these.
# SANITY_STUDIO_PROJECT_ID=
# SANITY_STUDIO_DATASET=production
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_VERSION=2025-04-13

# Phase 5: when true, load site copy and case studies from Sanity (with static fallback on errors).
# USE_SANITY_CONTENT=true

# Optional: only if the dataset is private or you need elevated API access
# SANITY_API_READ_TOKEN=

# Phase 3+ seed / migration scripts only (never expose to the browser).
# After setting this, run: yarn migrate:sanity
# SANITY_API_WRITE_TOKEN=

# Phase 6: GROQ webhook signing secret (sanity.io/manage → API → Webhooks). Must match the secret in the webhook form.
# URL: https://<your-host>/api/revalidate/sanity
# Projection example: { _type, _id, locale, "slug": slug.current }
# SANITY_REVALIDATE_SECRET=
