# Sanity (Phase 1) — copy to `.env.local` and fill in from https://www.sanity.io/manage
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_VERSION=2025-04-13

# Optional: only if the dataset is private or you need elevated API access
# SANITY_API_READ_TOKEN=

# Phase 3+ seed / migration scripts only (never expose to the browser)
# SANITY_API_WRITE_TOKEN=

# Phase 6+ webhook revalidation secret
# SANITY_REVALIDATE_SECRET=
